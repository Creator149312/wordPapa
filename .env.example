# ============================================
# WORDPAPA - ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to version control

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Connection URI
# Free tier: https://www.mongodb.com/get-started/atlas/signup
# Example: mongodb+srv://user:pass@cluster.mongodb.net/wordpapa?retryWrites=true&w=majority
MONGODB_URI=

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
# Secret key for NextAuth JWT signing
# Generate with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=

# Next.js app URL (for local development: http://localhost:3000)
# Production: https://yourdomain.com
NEXTAUTH_URL=

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
# Get from: https://console.cloud.google.com/
# Steps:
# 1. Create new Google Cloud project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add these redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (local)
#    - https://yourdomain.com/api/auth/callback/google (production)
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# OPTIONAL: ANALYTICS & TRACKING
# ============================================
# Google Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ============================================
# OPTIONAL: API CONFIGURATION
# ============================================
# Public API URL (accessible from browser)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Comma-separated list of emails allowed to access /admin/* pages
# Example: admin@example.com,owner@example.com
# Uses NEXT_PUBLIC_ prefix so client-side admin pages can read it
NEXT_PUBLIC_ADMIN_EMAILS=
